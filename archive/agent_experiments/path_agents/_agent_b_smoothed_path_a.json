{
  "derivation_summary": {
    "chain": "f_eps = f*h_eps with h_eps=(1/eps)1_{[-eps/2,eps/2]}; g_eps = f_eps*f_eps = g*phi_eps. Rescale to [-1/4,1/4] via g(y)=(1+2eps)f_eps((1+2eps)y). ||g_eps||_2^2 <= [1 + mu((1+2eps)M) * ((1+2eps)K_eps - 1)]/(1+2eps).",
    "mo_214_support_issue": "f_eps has support [-1/4-eps/2, 1/4+eps/2], larger than [-1/4, 1/4]. Rescaling to [-1/4,1/4] inflates M_eff to (1+2eps)*M and K_eff to (1+2eps)*K_eps, so MO 2.14 applies but with mu((1+2eps)*M) > mu(M).",
    "K_eps_naive_bound": "K_eps <= ||phi_eps||_inf = 1/eps (when int f = 1).",
    "K_eps_loose_at_small_eps": "As eps -> 0, naive K_eps -> infinity. Tight bound depends on f and is K_eps -> K = ||f||_2^2."
  },
